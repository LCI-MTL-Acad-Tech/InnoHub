# Generated at runtime — never commit
data/embeddings/
data/documents/
data/students/*.json
data/companies/*.json
data/projects/*.json
data/coordinators/*.json
man/
config.toml

# Input documents — never commit personal or confidential files
*.pdf
*.doc
*.docx
*.txt
*.html

# Output data — never commit
data/*.csv
data/audit.log

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# OS
.DS_Store

# Keep the empty dirs tracked by git
!data/embeddings/.gitkeep
!data/documents/students/.gitkeep
!data/documents/companies/.gitkeep
!data/documents/projects/.gitkeep
!data/documents/coordinators/.gitkeep
!data/students/.gitkeep
!data/companies/.gitkeep
!data/projects/.gitkeep
!data/coordinators/.gitkeep
!man/.gitkeep
